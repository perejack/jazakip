# Copy this file to ".env.local" (for Vite dev) and fill in values.
# Never commit real secrets.

# ----------------------------
# Vercel Serverless Functions
# ----------------------------
# Used by /api/stk-push and /api/payment-status in production (set these in Vercel project settings).
SWIFTPAY_API_KEY=your_swiftpay_api_key_here
SWIFTPAY_TILL_ID=your_swiftpay_till_id_here
SWIFTPAY_BASE_URL=https://swiftpay-backend-uvv9.onrender.com

# ----------------------------
# Vite (browser-exposed) vars
# ----------------------------
# Only required for *local development* when the app calls SwiftPay directly (not via /api/*).
# IMPORTANT: Anything prefixed with VITE_ is bundled into the client and is NOT secret.
VITE_SWIFTPAY_API_KEY=your_dev_only_swiftpay_api_key_here
VITE_SWIFTPAY_TILL_ID=your_dev_only_swiftpay_till_id_here
VITE_SWIFTPAY_BASE_URL=https://swiftpay-backend-uvv9.onrender.com

